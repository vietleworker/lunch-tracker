# ─── Lunch Tracker — config template ───
# Copy to .env and fill in real values. .env is gitignored.

# Cloudflare — deploy the Worker
CLOUDFLARE_API_TOKEN=cfat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Worker (API)
WORKER_URL=https://your-worker.workers.dev
WORKER_SECRET=your-worker-secret

# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# App URLs
APP_URL=https://your-project-id.web.app
SHARE_PAGE_URL=https://your-project-id.web.app/update-bill.html?bill=N
